{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@src/(.*)$": "<rootDir>/src/$1" 
  },
  "globals": {
    "ts-jest": {
      "useESM": true  
    }
  },
  "preset": "ts-jest/presets/js-with-ts-esm"
}
